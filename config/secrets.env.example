# personal-os — secrets (TEMPLATE)
# Copy this to `secrets.env` (install.sh does it for you) and fill in real values.
# `secrets.env` is gitignored. NEVER commit real values — this repo is PUBLIC,
# and a single committed secret is permanently compromised.

# Telegram bot token from @BotFather (https://t.me/BotFather). Required for the bot.
TELEGRAM_BOT_TOKEN=

# OpenRouter API key (https://openrouter.ai/keys). Needed to transcribe voice messages.
# Lets you pick any STT model via config.voice.model (default openai/whisper-large-v3).
OPENROUTER_API_KEY=

# Optional: only needed if you later swap the engine adapter from the local
# `claude` CLI to a direct API. Not used by the default CLI engine.
# ANTHROPIC_API_KEY=
